UPSTREAM_BASE_URL=https://opencode.ai/zen/v1

PORT=3000
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=5
LOG_FILE_ENABLED=true

# EXA_API_KEY=                     # Exa 搜索 key（免费 tier 不用配）
WEB_SEARCH_ENABLED=true            # 联网搜索开关
VISION_ENABLED=true                # VLM 识图开关
VISION_API_KEY=                    # VLM API key
VISION_BASE_URL=https://token.sensenova.cn/v1  # VLM 端点
VISION_MODEL=sensenova-6.7-flash-lite          # VLM 模型
VISION_PROMPT_FILE=./src/VISION_PROMPT.md
VISION_TIMEOUT_MS=60000            # VLM 请求超时（毫秒，默认 1 分钟）

# CACHE_MONITOR=true               # 缓存暴跌监控（可选，写文件不刷控制台）
VISION_CACHE_TTL=604800            # 磁盘缓存过期（秒，默认 7 天）
VISION_CACHE_MEM_MAX=200           # 热缓存最大条目数
VISION_CACHE_DIR=./data/vision-cache  # 磁盘缓存目录
